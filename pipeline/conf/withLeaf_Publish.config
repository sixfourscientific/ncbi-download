
process {

    withName: 'Taxonomy:DownloadCustom:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', 'taxonomy', CoreMeta.RUN, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    ////LEAF_CONFIG////

    }
