
process {

    withName: 'Taxonomy:DownloadCustom:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', 'taxonomy', CoreMeta.RUN, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    withName: 'Query:SummaryDatasets:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', 'DATASETS', 'SUMMARY', CoreMeta.RUN, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    withName: 'Format:TabulateCustom:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', CoreMeta.name, 'CUSTOM', 'TABULATE', CoreMeta.RUN, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    withName: 'Fetch:DownloadDatasets:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', CoreMeta.name, 'DATASETS', 'DOWNLOAD', CoreMeta.RUN, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    ////LEAF_CONFIG////

    }
